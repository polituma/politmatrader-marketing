# =============================================================================
# POLITMATRADER AI Marketing System — Environment Configuration
# =============================================================================
# Copy to .env and fill in production values before deploying.

# ---- Application ----
APP_ENV=production
LOG_LEVEL=INFO
BASE_URL=http://127.0.0.1:8000
DEFAULT_TIMEZONE=America/New_York

# ---- Database ----
# SQLite for dev; use PostgreSQL for production:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/politma
DATABASE_URL=sqlite:///./politma_marketing.db

# ---- Brand Configuration ----
BRAND_NAME=POLITMATRADER
BRAND_DOMAIN=https://politmatrader.com
PRIMARY_OFFER=Trading Challenges
COUPON_CODE=EASTER20
COUPON_DESCRIPTION=20% OFF all challenges for the month of April
CTA_PRIMARY=Start Challenge Now
CTA_SECONDARY=Visit PolitmaTrader.com
BRAND_PRIMARY_COLOR=#000000
BRAND_ACCENT_COLOR=#C8A95A

# ---- Scheduling ----
ENABLE_AUTOPUBLISH=false
SCHEDULER_DAILY_HOUR=7
SCHEDULER_DAILY_MINUTE=0

# ---- API Security ----
# Comma-separated list of valid API keys for protected endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=

# Secret used to verify inbound webhook signatures (HMAC-SHA256).
WEBHOOK_SECRET=

# ---- CORS ----
# Comma-separated allowed origins. Use * only in development.
CORS_ORIGINS=https://politmatrader.com

# ---- Publishing Webhook (outbound) ----
PUBLISH_WEBHOOK_URL=
PUBLISH_WEBHOOK_TOKEN=

# ---- AI Content Webhook (outbound) ----
AI_WEBHOOK_URL=
AI_WEBHOOK_TOKEN=

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=60
